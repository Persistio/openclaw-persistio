{
  "name": "@persistio/openclaw-plugin",
  "version": "0.1.3",
  "description": "OpenClaw plugin for Persistio \u2014 persistent semantic memory for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "openclaw.plugin.json",
    "README.md"
  ],
  "license": "MIT",
  "author": "Chris Coveyduck",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/persistio/openclaw-persistio.git"
  },
  "homepage": "https://persistio.ai",
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "ai",
    "agents",
    "persistio"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  }
}
