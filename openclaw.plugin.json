{
  "id": "openclaw-persistio",
  "name": "Persistio Memory",
  "description": "Persistent semantic memory for OpenClaw via Persistio",
  "version": "0.1.4",
  "kind": "memory",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "memory_search",
      "memory_add",
      "memory_delete",
      "memory_list"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "baseURL": {
        "type": "string"
      },
      "apiKey": {
        "type": "string"
      },
      "tokenBudget": {
        "type": "number"
      },
      "recallTopK": {
        "type": "number"
      },
      "recallTimeout": {
        "type": "number"
      },
      "send": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "roles": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "user": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled"
                ]
              },
              "agent": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled"
                ]
              },
              "tool": {
                "type": "string",
                "enum": [
                  "enabled",
                  "disabled"
                ]
              }
            }
          }
        }
      }
    },
    "required": [
      "baseURL",
      "apiKey"
    ]
  }
}
